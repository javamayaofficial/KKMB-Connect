APP_NAME="KKMB Connect"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://kkmbconnect.example.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

# ---------- DATABASE (MySQL / MariaDB) ----------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kkmb_connect
DB_USERNAME=kkmb_user
DB_PASSWORD=

# ---------- SESSION / CACHE / QUEUE ----------
# Queue pakai database agar kompatibel FastPanel & cPanel (tanpa Redis)
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# ---------- FILESYSTEM ----------
FILESYSTEM_DISK=public

# ---------- WHATSAPP ----------
# Provider utama: Fonnte. Alternatif: onesender / starsender
WHATSAPP_PROVIDER=fonnte
FONNTE_TOKEN=
FONNTE_DEVICE=
# ONESENDER_TOKEN=
# ONESENDER_URL=
# STARSENDER_TOKEN=

# ---------- EMAIL ----------
# Provider utama: Mailketing. Alternatif: kirim_email
EMAIL_PROVIDER=mailketing
MAILKETING_API_TOKEN=
MAIL_FROM_ADDRESS=no-reply@kkmbconnect.example.com
MAIL_FROM_NAME="KKMB Connect"
# KIRIMEMAIL_API_TOKEN=

# Fallback SMTP standar Laravel (dipakai bila provider di atas kosong)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null

# ---------- PAYMENT ----------
# MVP: manual_transfer. Fallback: qris_manual. (gateway=midtrans di fase 2)
PAYMENT_PROVIDER=manual_transfer
BANK_NAME="Bank BCA"
BANK_ACCOUNT_NO="1234567890"
BANK_ACCOUNT_NAME="Koperasi KKMB"
QRIS_IMAGE_PATH="images/qris.png"
# MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=
# MIDTRANS_IS_PRODUCTION=false

# ---------- BUILDER CREDIT (jangan diubah tanpa izin) ----------
BUILDER_NAME="Java Maya Studio"
BUILDER_WA="https://wa.me/6285722224391"
